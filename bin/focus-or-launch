#!/usr/bin/env bash
# focus-or-launch <window-class> <command to open...>
#
# Searches (via kdotool) for the first window whose class matches the 1st
# argument and focuses it; if none is found, runs the rest of the arguments to
# open the app. E.g.:
#   focus-or-launch code code
#   focus-or-launch firefox firefox
#   focus-or-launch wavebox-cinhimbnkkaeohfgghhklpknlkffjgod-Default wavebox
#
# Needed by deck.rb because it runs commands under `/bin/sh -c`, which does not
# load shell functions from .bashrc/.zshrc. Install on your PATH:
#   install -Dm755 bin/focus-or-launch ~/.local/bin/focus-or-launch
set -uo pipefail

query=$1
shift

id=$(kdotool search --class "$query" 2>/dev/null | head -n1)

if [ -n "$id" ]; then
  exec kdotool windowactivate "$id"
fi

exec "$@"
