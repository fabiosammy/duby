#!/usr/bin/env bash
# deck-tray-daemon — start the tray (bin/deck-tray) in the nix-shell, which in
# turn supervises deck.rb. Use this in KDE autostart.
#
# Forces QT_QPA_PLATFORM=xcb: the tray icon (SNI, via D-Bus) shows up just the
# same, and we avoid depending on the Qt-Wayland plugin inside the nix-shell.
# Requires XWayland (enabled by default on Plasma Wayland).
set -uo pipefail

HERE="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
cd "$HERE" || exit 1

export PATH="$HOME/.local/bin:$HOME/.nix-profile/bin:/run/current-system/sw/bin:/etc/profiles/per-user/$USER/bin:$PATH"
NIX_SHELL="$(command -v nix-shell || echo /run/current-system/sw/bin/nix-shell)"

exec "$NIX_SHELL" --run "QT_QPA_PLATFORM=xcb python3 bin/deck-tray"
