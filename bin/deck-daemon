#!/usr/bin/env bash
# deck-daemon — start deck.rb in `run` mode inside the nix-shell, logging to a
# file. Meant for KDE autostart or a systemd --user service.
#
#   bin/deck-daemon            # runs in foreground (log also goes to deck.log)
#
# The log lives at <project>/deck.log. Stop with:  bin/deck-stop (paints goodbye).
set -uo pipefail

# project directory (parent of bin/)
HERE="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
cd "$HERE" || exit 1

LOG="$HERE/deck.log"

# ensure PATH has: user tools, nix profile and system profile — needed to find
# nix-shell, cycle-or-launch (~/.local/bin), kdotool, etc.
export PATH="$HOME/.local/bin:$HOME/.nix-profile/bin:/run/current-system/sw/bin:/etc/profiles/per-user/$USER/bin:$PATH"

NIX_SHELL="$(command -v nix-shell || echo /run/current-system/sw/bin/nix-shell)"

{
  echo
  echo "==================== $(date '+%Y-%m-%d %H:%M:%S') :: starting ===================="
} >>"$LOG"

# everything (stdout+stderr) appended to the log.
exec "$NIX_SHELL" --run "ruby deck.rb run deck.yml" >>"$LOG" 2>&1
