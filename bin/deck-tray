#!/usr/bin/env python3
"""KDE system-tray app for the FIFINE Deck.

Uses QSystemTrayIcon (Qt6/PySide6), which speaks KDE's StatusNotifierItem
protocol — unlike `yad`'s GtkStatusIcon, this shows up in the Plasma systray
even on Wayland.

The tray supervises `ruby deck.rb run deck.yml` as a child process: it starts
on open, and the menu lets you Stop/Start/Restart/Open log/Quit. Stop and Quit
send SIGTERM to ruby, which triggers the "Deck OFF" screen.

Run via bin/deck-tray-daemon (which enters the nix-shell and forces QT_QPA_PLATFORM=xcb).
"""
import signal
import subprocess
import sys
from pathlib import Path

from PySide6.QtCore import QTimer
from PySide6.QtGui import QAction, QIcon
from PySide6.QtWidgets import QApplication, QMenu, QSystemTrayIcon

HERE = Path(__file__).resolve().parent.parent  # project directory (duby/)
LOG = HERE / "deck.log"
CONFIG = "deck.yml"


class DeckTray:
    def __init__(self, app: QApplication):
        self.app = app
        self.proc: subprocess.Popen | None = None
        self.logf = None

        self.tray = QSystemTrayIcon()
        menu = QMenu()
        self.status_action = QAction("…", enabled=False)
        self.toggle_action = QAction("Start", triggered=self.toggle)
        self.restart_action = QAction("Restart", triggered=self.restart)
        self.log_action = QAction("Open log", triggered=self.open_log)
        self.quit_action = QAction("Quit", triggered=self.quit)

        menu.addAction(self.status_action)
        menu.addSeparator()
        menu.addAction(self.toggle_action)
        menu.addAction(self.restart_action)
        menu.addSeparator()
        menu.addAction(self.log_action)
        menu.addSeparator()
        menu.addAction(self.quit_action)

        self.tray.setContextMenu(menu)
        self.tray.activated.connect(self.on_activate)
        self.tray.show()

        self.timer = QTimer()
        self.timer.timeout.connect(self.refresh)
        self.timer.start(1500)

        self.start()  # start the deck as soon as the tray opens
        self.refresh()

    # ── process state ─────────────────────────────────────────────────────────
    def running(self) -> bool:
        return self.proc is not None and self.proc.poll() is None

    def start(self):
        if self.running():
            return
        self.logf = open(LOG, "a", buffering=1)
        self.proc = subprocess.Popen(
            ["ruby", "deck.rb", "run", CONFIG],
            cwd=str(HERE),
            stdout=self.logf,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )

    def stop(self):
        if self.running():
            try:
                self.proc.terminate()          # SIGTERM to ruby -> paints "Deck OFF"
                self.proc.wait(timeout=6)
            except Exception:
                try:
                    self.proc.kill()
                except Exception:
                    pass
        self.proc = None
        if self.logf:
            try:
                self.logf.close()
            except Exception:
                pass
            self.logf = None

    # ── menu actions ──────────────────────────────────────────────────────────
    def toggle(self):
        self.stop() if self.running() else self.start()
        self.refresh()

    def restart(self):
        self.stop()
        self.start()
        self.refresh()

    def open_log(self):
        subprocess.Popen(["xdg-open", str(LOG)])

    def on_activate(self, reason):
        if reason == QSystemTrayIcon.ActivationReason.Trigger:  # left click
            self.toggle()

    def refresh(self):
        run = self.running()
        self.tray.setIcon(QIcon.fromTheme("input-gaming" if run else "input-keyboard"))
        self.tray.setToolTip("FIFINE Deck: " + ("listening" if run else "stopped"))
        self.status_action.setText("●  Running" if run else "○  Stopped")
        self.toggle_action.setText("Stop" if run else "Start")

    def quit(self):
        self.stop()
        self.app.quit()


def main():
    app = QApplication(sys.argv)
    app.setQuitOnLastWindowClosed(False)
    if not QSystemTrayIcon.isSystemTrayAvailable():
        print("Warning: system tray unavailable in this session.", file=sys.stderr)

    tray = DeckTray(app)

    # clean shutdown on logout (SIGTERM) / Ctrl-C (SIGINT)
    signal.signal(signal.SIGTERM, lambda *_: tray.quit())
    signal.signal(signal.SIGINT, lambda *_: tray.quit())
    # nudge the Qt loop periodically so the Python signal handlers above run
    nudge = QTimer()
    nudge.start(400)
    nudge.timeout.connect(lambda: None)

    sys.exit(app.exec())


if __name__ == "__main__":
    main()
